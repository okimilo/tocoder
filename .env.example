# Upstream ToCodex endpoint. Leave as-is unless you have a private deployment.
TOCODEX_BASE_URL=https://api.tocodex.com

# Optional: if omitted, the proxy will forward the incoming Authorization / X-Api-Key.
TOCODEX_API_KEY=

# Same default secret used by the VS Code extension bundle.
TOCODEX_HMAC_SECRET=tc-hmac-s3cr3t-k3y-2026-tocodex-platform

# Matches the current bundled extension version by default.
TOCODEX_APP_VERSION=3.1.3

# Optional fallback model when the client omits model.
TOCODEX_DEFAULT_MODEL=gpt-5.4

TOCODEX_TIMEOUT_SECONDS=600
TOCODEX_TLS_VERIFY=true
TOCODEX_PROXY_LOG_LEVEL=INFO
